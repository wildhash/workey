FROM python:3.11-slim

WORKDIR /app

COPY packages/agents/pyproject.toml /app/packages/agents/pyproject.toml
COPY apps/worker/pyproject.toml /app/apps/worker/pyproject.toml

RUN pip install --no-cache-dir hatchling && \
    pip install --no-cache-dir -e /app/packages/agents && \
    pip install --no-cache-dir -e /app/apps/worker

COPY packages/agents/ /app/packages/agents/
COPY apps/worker/ /app/apps/worker/
COPY data/ /app/data/

CMD ["python", "-m", "apps.worker.main"]
